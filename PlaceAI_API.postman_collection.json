{
  "info": {
    "name": "PlaceAI – Student Placement Platform",
    "_postman_id": "placeai-placement-v1",
    "description": "Complete API collection for the FastAPI Student Placement & Recruitment Platform.\n\n## Quick Start\n1. Run the server: `cd FastAPI-JWT-Authentication && .venv/bin/uvicorn app.app:app --reload`\n2. Import this collection into Postman\n3. Run **Auth / Signup (Student)** → copy `access_token` → set the collection variable `student_token`\n4. Run **Auth / Signup (Recruiter)** → copy `access_token` → set `recruiter_token`\n5. Use the pre-built flows in order within each folder\n\n## Variables\n| Variable | Description |\n|---|---|\n| `base_url` | API root (default: http://localhost:8000) |\n| `student_token` | JWT for a student user |\n| `recruiter_token` | JWT for a recruiter user |\n| `job_id` | ID of a created job (fill after POST /jobs) |\n| `application_id` | ID of an application (fill after POST apply) |\n| `student_profile_id` | Student profile ID from GET /students/profile |",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",           "value": "http://localhost:8000", "type": "string" },
    { "key": "student_token",      "value": "",                      "type": "string" },
    { "key": "recruiter_token",    "value": "",                      "type": "string" },
    { "key": "job_id",             "value": "",                      "type": "string" },
    { "key": "application_id",     "value": "",                      "type": "string" },
    { "key": "student_profile_id", "value": "",                      "type": "string" }
  ],
  "item": [

    {
      "name": "🔑 Auth",
      "item": [

        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          },
          "response": [],
          "_description": "Verify the API is running before anything else."
        },

        {
          "name": "Signup — Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.id) {",
                  "  pm.test('Student signup successful', () => pm.expect(pm.response.code).to.equal(201));",
                  "  pm.collectionVariables.set('student_email', r.email);",
                  "  console.log('✅ Student created:', r.email, '| role:', r.role);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student_demo\",\n  \"email\": \"student@demo.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"student\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/signup", "host": ["{{base_url}}"], "path": ["auth", "signup"] }
          },
          "response": []
        },

        {
          "name": "Signup — Recruiter",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.id) {",
                  "  pm.test('Recruiter signup successful', () => pm.expect(pm.response.code).to.equal(201));",
                  "  console.log('✅ Recruiter created:', r.email, '| role:', r.role);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"recruiter_demo\",\n  \"email\": \"recruiter@demo.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"recruiter\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/signup", "host": ["{{base_url}}"], "path": ["auth", "signup"] }
          },
          "response": []
        },

        {
          "name": "Login — Student  ✦ sets student_token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "pm.test('Login successful', () => pm.expect(pm.response.code).to.equal(200));",
                  "if (r.access_token) {",
                  "  pm.collectionVariables.set('student_token', r.access_token);",
                  "  pm.collectionVariables.set('student_refresh_token', r.refresh_token);",
                  "  console.log('✅ student_token set');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "student@demo.com" },
                { "key": "password", "value": "Password123!" }
              ]
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          },
          "_description": "NOTE: /auth/login uses application/x-www-form-urlencoded (OAuth2 standard). The 'username' field holds the email.",
          "response": []
        },

        {
          "name": "Login — Recruiter  ✦ sets recruiter_token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "pm.test('Login successful', () => pm.expect(pm.response.code).to.equal(200));",
                  "if (r.access_token) {",
                  "  pm.collectionVariables.set('recruiter_token', r.access_token);",
                  "  pm.collectionVariables.set('recruiter_refresh_token', r.refresh_token);",
                  "  console.log('✅ recruiter_token set');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "recruiter@demo.com" },
                { "key": "password", "value": "Password123!" }
              ]
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          },
          "response": []
        },

        {
          "name": "Refresh Token (Student)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{student_refresh_token}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/refresh", "host": ["{{base_url}}"], "path": ["auth", "refresh"] }
          },
          "response": []
        },

        {
          "name": "Get Current User (Student)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{student_token}}" }],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          },
          "response": []
        },

        {
          "name": "Get Current User (Recruiter)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{recruiter_token}}" }],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          },
          "response": []
        },

        {
          "name": "Google OAuth Sign-In",
          "_description": "Send the ID token from Google Identity Services. The role field only matters for new users.",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credential\": \"<PASTE_GOOGLE_ID_TOKEN_HERE>\",\n  \"role\": \"student\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/google", "host": ["{{base_url}}"], "path": ["auth", "google"] }
          },
          "response": []
        }

      ]
    },

